---
import type { Locale } from '../i18n/types';
import { t } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<footer class="footer">
  <p>{t(locale, 'footer.tagline')}</p>
  <p class="copyright" set:html={t(locale, 'footer.copyright')} />
  <nav class="footer-links" aria-label="Footer links">
    <a href="https://github.com/adrozdenko/soleri" target="_blank" rel="noreferrer">GitHub</a>
    <a href="https://www.npmjs.com/package/soleri" target="_blank" rel="noreferrer">npm</a>
    <a href="https://soleri.ai" target="_blank" rel="noreferrer">soleri.ai</a>
  </nav>
</footer>

---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const navLinks = [
  { href: '/en/how-it-works.html', label: 'How it works' },
  { href: '/en/personas.html', label: 'Your Agent' },
  { href: '/en/teams.html', label: 'Teams' },
  { href: '/en/community.html', label: 'Community' },
  { href: '/docs/', label: 'Docs' },
  { href: '/en/getting-started.html', label: 'Get started' },
];
---
<div class="header soleri-header">
  <div class="soleri-brand">
    <a href="/en/">
      <p class="soleri-brand-name">Soleri</p>
    </a>
  </div>
  <nav class="soleri-nav-links" aria-label="Site navigation">
    {navLinks.map(link => (
      <a href={link.href} class={link.href === '/docs/' ? 'active' : ''}>{link.label}</a>
    ))}
  </nav>
  <div class="soleri-header-right sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
    <div class="sl-hidden md:sl-flex right-group sl-flex">
      <ThemeSelect />
      <LanguageSelect />
    </div>
  </div>
</div>

<style>
  .soleri-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 100%;
    max-width: 1120px;
    margin: 0 auto;
    width: 100%;
  }

  .soleri-brand a {
    text-decoration: none;
    color: inherit;
  }

  .soleri-brand-name {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sl-color-white);
    margin: 0;
    white-space: nowrap;
  }

  .soleri-nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .soleri-nav-links a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 8px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .soleri-nav-links a:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
  }

  .soleri-nav-links a.active {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
    font-weight: 600;
  }

  .soleri-header-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .right-group {
    gap: 0.5rem;
    align-items: center;
  }

  @media (max-width: 820px) {
    .soleri-nav-links {
      display: none;
    }
  }
</style>

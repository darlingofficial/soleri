---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const currentLocale = Astro.locals.starlightRoute.locale;
const currentPath = Astro.url.pathname;

/**
 * Build locale-aware URL: root locale = /docs/*, others = /{locale}/docs/*
 */
function localizedHref(code: string): string {
  const stripped = currentPath.replace(/^\/(uk|it)\//, '/');
  if (code === 'root') return stripped;
  return `/${code}${stripped}`;
}

/* Resolve website locale prefix for nav links */
const webLocale = currentLocale === 'root' || currentLocale === undefined ? 'en' : currentLocale;
const webPrefix = `/${webLocale}/`;

const navLinks = [
  { href: `${webPrefix}how-it-works.html`, label: navLabel('nav.how', 'How it works') },
  { href: `${webPrefix}personas.html`, label: navLabel('nav.agent', 'Your Agent') },
  { href: `${webPrefix}teams.html`, label: navLabel('nav.teams', 'Teams') },
  { href: `${webPrefix}articles.html`, label: navLabel('nav.articles', 'Articles') },
  { href: `${webPrefix}community.html`, label: navLabel('nav.community', 'Community') },
  { href: '/docs/getting-started/', label: navLabel('nav.docs', 'Docs'), active: true },
  { href: `${webPrefix}getting-started.html`, label: navLabel('nav.start', 'Get started') },
];

function navLabel(_key: string, fallback: string): string {
  /* i18n labels — extend as needed */
  const labels: Record<string, Record<string, string>> = {
    'nav.how':       { en: 'How it works', uk: 'Як це працює', it: 'Come funziona' },
    'nav.agent':     { en: 'Your Agent', uk: 'Твій агент', it: 'Il tuo agente' },
    'nav.teams':     { en: 'Teams', uk: 'Команди', it: 'Team' },
    'nav.articles':  { en: 'Articles', uk: 'Статті', it: 'Articoli' },
    'nav.community': { en: 'Community', uk: 'Спільнота', it: 'Community' },
    'nav.docs':      { en: 'Docs', uk: 'Документація', it: 'Documentazione' },
    'nav.start':     { en: 'Get started', uk: 'Почати', it: 'Inizia ora' },
  };
  return labels[_key]?.[webLocale] ?? fallback;
}

const langs = Object.entries(config.locales).map(([code, locale]) => ({
  code: code === 'root' ? 'en' : code,
  label: (code === 'root' ? 'EN' : code).toUpperCase(),
  href: localizedHref(code),
  selected: code === currentLocale,
}));
---

<div class="header sl-header">
  <div class="sl-header-brand">
    <a href={`/${webLocale}/`} class="sl-brand-link">
      <span class="sl-brand-name">Soleri</span>
    </a>
  </div>

  <nav class="sl-header-nav" aria-label="Site navigation">
    {navLinks.map(link => (
      <a href={link.href} class:list={['sl-nav-link', { active: link.active }]}>{link.label}</a>
    ))}
  </nav>

  <div class="sl-header-actions">
    {shouldRenderSearch && <Search />}

    <a href="https://github.com/adrozdenko/soleri" class="sl-github-link" aria-label="GitHub" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
    </a>

    {config.isMultilingual && (
      <div class="sl-lang-switcher">
        {langs.map(l => (
          <a href={l.href} class:list={[{ active: l.selected }]}>{l.label}</a>
        ))}
      </div>
    )}

    <button class="sl-theme-toggle" id="sl-theme-toggle" type="button" aria-label="Toggle color theme">
      <span class="sl-toggle-track">
        <span class="sl-toggle-thumb">
          <svg class="sl-icon sl-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="sl-icon sl-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
        <span class="sl-toggle-bg sl-toggle-bg-sun">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
        <span class="sl-toggle-bg sl-toggle-bg-moon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
      </span>
    </button>
  </div>
</div>

<script is:inline>
(function () {
  var btn = document.getElementById('sl-theme-toggle');
  if (!btn) return;

  function setTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    btn.setAttribute('aria-label', t === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
    localStorage.setItem('starlight-theme', t);
  }

  var saved = localStorage.getItem('starlight-theme');
  if (saved) setTheme(saved);

  btn.addEventListener('click', function () {
    var current = document.documentElement.getAttribute('data-theme');
    var next = current === 'dark' ? 'light' : 'dark';
    setTheme(next);
  });
})();
</script>
